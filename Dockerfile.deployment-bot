# The deployment bot is published separately so it remains usable when the
# main housebot image fails to build or has a bad runtime release.
FROM docker:27-cli AS docker-cli

FROM rust:1-alpine AS rust-builder
RUN apk add --no-cache musl-dev
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/common-crawl/Cargo.toml crates/common-crawl/Cargo.toml
COPY crates/common-crawl/src/ crates/common-crawl/src/
COPY crates/graph-render/Cargo.toml crates/graph-render/Cargo.toml
COPY crates/graph-render/src/ crates/graph-render/src/
COPY crates/llm/Cargo.toml crates/llm/Cargo.toml
COPY crates/llm/src/ crates/llm/src/
COPY crates/deployment-bot/Cargo.toml crates/deployment-bot/Cargo.toml
COPY crates/deployment-bot/src/ crates/deployment-bot/src/
RUN --mount=type=cache,id=deployment-bot-cargo-registry,target=/usr/local/cargo/registry \
    --mount=type=cache,id=deployment-bot-cargo-git,target=/usr/local/cargo/git \
    --mount=type=cache,id=deployment-bot-cargo-target,target=/app/target \
    cargo build --release --locked --package deployment-bot \
    && cp /app/target/release/deployment-bot /app/deployment-bot \
    && strip /app/deployment-bot

FROM alpine:3.22
RUN apk add --no-cache ca-certificates

COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=rust-builder /app/deployment-bot /usr/local/bin/deployment-bot

CMD ["deployment-bot"]
