# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Your Discord user ID — required to approve run_claude_code tool calls
# Enable Developer Mode in Discord settings, then right-click your username → Copy User ID
OWNER_DISCORD_ID=your-discord-user-id-here

# LLM — OpenAI-compatible endpoint (llama.cpp)
LLM_BASE_URL=http://server-slop:8080/v1
LLM_MODEL=gemma-4-12b-qat-q4kxl
# LLM_API_KEY=not-required   # llama.cpp doesn't need a real key

# Jellyfin media server (leave blank to disable Jellyfin MCP)
JELLYFIN_URL=https://your-jellyfin-server:8096
JELLYFIN_API_KEY=your-jellyfin-api-key-here

# Claude Code auth — OAuth token from running `claude` interactively once on the host,
# then copying CLAUDE_CODE_OAUTH_TOKEN out of ~/.claude/credentials.json
CC_OAUTH_TOKEN=

# Sandbox — ephemeral Docker containers, one per request
# SANDBOX_IMAGE=house-chatbot-sandbox:latest   # built via: docker compose build sandbox
# DOCKER_NETWORK=house-chatbot_default         # network the containers join
# SANDBOX_TIMEOUT=300

# OpenCode — llama.cpp server (reachable from inside the sandbox container)
LLAMA_CPP_URL=http://server-slop:8080
LLAMA_CPP_MODEL=gemma-4-12b-qat-q4kxl

# Optional: conversation history
# MAX_HISTORY_TURNS=30   # number of user/assistant turn pairs to keep
