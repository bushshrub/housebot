# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Your Discord user ID (the bot owner)
# Enable Developer Mode in Discord settings, then right-click your username → Copy User ID
OWNER_DISCORD_ID=your-discord-user-id-here

# Optional: Discord server ID for instant deployment slash-command sync.
# If omitted, /deploy, /update, and /rollback are registered globally and may take up to an hour to appear.
# Enable Developer Mode, then right-click the server name → Copy Server ID.
# DEPLOYMENT_GUILD_ID=your-discord-server-id-here

# LLM — OpenAI-compatible endpoint (llama.cpp)
LLM_BASE_URL=http://server-slop:8080/v1
LLM_MODEL=gemma-4-12b-qat-q4kxl
# LLM_API_KEY=not-required   # llama.cpp doesn't need a real key

# Jellyfin media server (leave blank to disable Jellyfin MCP)
JELLYFIN_URL=https://your-jellyfin-server:8096
JELLYFIN_API_KEY=your-jellyfin-api-key-here

# Claude Code auth — OAuth token from running `claude` interactively once on the host,
# then copying CLAUDE_CODE_OAUTH_TOKEN out of ~/.claude/credentials.json
CC_OAUTH_TOKEN=

# Sandbox — ephemeral Docker containers, one per request
# SANDBOX_IMAGE=ghcr.io/bushshrub/housebot/sandbox:latest   # from GitHub Container Registry
# SANDBOX_IMAGE=house-chatbot-sandbox:latest                # or build locally: docker compose build sandbox
# DOCKER_NETWORK=house-chatbot_default                      # network the containers join
# SANDBOX_TIMEOUT=300

# OpenCode — llama.cpp server (reachable from inside the sandbox container)
LLAMA_CPP_URL=http://server-slop:8080
LLAMA_CPP_MODEL=gemma-4-12b-qat-q4kxl

# Optional: conversation history
# MAX_HISTORY_TURNS=30   # number of user/assistant turn pairs to keep

# Sentry — error tracking (required for error reporting)
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# GitHub App — for filing issues (feature requests + Sentry-backed error reports)
# All four required to enable GitHub issue creation.
# 1. Create a GitHub App at https://github.com/settings/apps/new
#    Permissions: Issues → Read & Write
# 2. Generate a private key (PEM), paste it below with literal \n between lines
# 3. Install the app on the target repo, then grab the Installation ID from
#    https://github.com/settings/installations → your app → URL ends in /<id>
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
# GITHUB_INSTALLATION_ID=12345678
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=master
